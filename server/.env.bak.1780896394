# api 컨테이너가 읽는 백엔드 환경변수 (git 미추적: .gitignore의 .env).
# 호스트 PostgreSQL hansolax 클러스터(포트 5433)에 접속.
# host.docker.internal = 컨테이너에서 본 호스트. docker-compose의 extra_hosts로 매핑됨.
DATABASE_URL=postgresql://hansolax:hansol0513@host.docker.internal:5433/hansolax

# === 인증 / JWT ===
# 운영용 시크릿. 아래 명령으로 랜덤 생성: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=Vt2dlUsxkO0h_VKy4bGj1q232y9D48WKgiblRpI3yXDe6wRaJ3Zn54fe9sSkQ8tP
# === 가입 허용 이메일 도메인 (쉼표로 구분) ===
#  ★★ 도메인을 바꾸려면 여기만 수정하고 ./deploy.sh 다시 실행하면 됩니다. ★★
ALLOWED_EMAIL_DOMAINS=hansolax.com

# === Gmail SMTP (인증 메일 발송) ===
