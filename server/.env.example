# 환경 변수 예시. 복사해서 .env 로 사용하세요.

# 호스트 PostgreSQL(hansolax 클러스터, 5433). 컨테이너→호스트는 host.docker.internal 사용.
DATABASE_URL=postgresql://hansolax:<password>@host.docker.internal:5433/hansolax

# === 인증 / JWT ===
# python -c "import secrets; print(secrets.token_urlsafe(48))" 로 생성한 랜덤 문자열
JWT_SECRET=<long-random-string>

# === 가입 허용 이메일 도메인 (쉼표로 구분) ===
ALLOWED_EMAIL_DOMAINS=

# === Gmail SMTP (인증 메일 발송) ===
# Gmail "앱 비밀번호"(16자리)를 사용하세요(일반 비번 아님).
SMTP_USER=<your-gmail@gmail.com>
SMTP_PASSWORD=<gmail-app-password>
SMTP_FROM=

# 인증 링크/리다이렉트 기준 URL
APP_BASE_URL=