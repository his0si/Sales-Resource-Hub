# 환경 변수 예시. 복사해서 .env 로 사용하세요.

# 호스트 PostgreSQL(hansolax 클러스터, 5433). 컨테이너→호스트는 host.docker.internal 사용.
DATABASE_URL=postgresql://hansolax:<password>@host.docker.internal:5433/hansolax

# === 인증 / JWT ===
# python -c "import secrets; print(secrets.token_urlsafe(48))" 로 생성한 랜덤 문자열
JWT_SECRET=<long-random-string>

# === 가입 허용 이메일 도메인 (쉼표로 구분) ===
ALLOWED_EMAIL_DOMAINS=

# === Gmail SMTP (인증 메일 발송) ===
# Gmail "앱 비밀번호"(16자리)를 사용하세요(일반 비번 아님).
SMTP_USER=<your-gmail@gmail.com>
SMTP_PASSWORD=<gmail-app-password>
SMTP_FROM=

# 인증 링크/리다이렉트 기준 URL
APP_BASE_URL=

# === Gmail API (메일 읽기, OAuth2) ===
# Google Cloud Console > OAuth 2.0 클라이언트 ID 에서 발급.
GMAIL_CLIENT_ID=<oauth-client-id>
GMAIL_CLIENT_SECRET=<oauth-client-secret>
# scripts/gmail_authorize.py 를 1회 실행해 발급받은 값.
GMAIL_REFRESH_TOKEN=<refresh-token>
# 읽을 메일 계정(표시·확인용). 계정을 바꾸면 refresh token 도 재발급해야 함.
GMAIL_MAILBOX=ai.hansolhomedeco@gmail.com

# === 영업일지 메일 자동 적재 (백엔드 폴링) ===
# [HSP SalesMemo] 메일을 주기적으로 파싱해 sales_memo 테이블에 upsert 한다. (기본값으로 동작, 보통 손댈 필요 없음)
SALES_MEMO_SYNC_ENABLED=true
SALES_MEMO_POLL_SECONDS=300
SALES_MEMO_QUERY=subject:"HSP SalesMemo"
SALES_MEMO_MAX_SCAN=30